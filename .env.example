# Rename this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# Do NOT commit .env to source control — it contains sensitive credentials.
#
# Keys marked [Stream] are used by Add-TranscriptsToGraphForStreamUpload.ps1
# Keys marked [Teams]  are used by Add-TranscriptsToGraphForTeamsMeeting.ps1
# Keys marked [Both]   are used by both scripts

# ── Shared settings [Both] ───────────────────────────────────────────────────

# Entra App (client) ID registered in your tenant.
# Needs read access to SharePoint (Stream) and app-only cert access (Teams).
CLIENT_ID=

# Tenant name (e.g., contoso.onmicrosoft.com).
TENANT=

# Thumbprint of the certificate used for app-only authentication.
CERT_THUMBPRINT=

# URL of your SharePoint Admin center, used for the app-only PnP connection.
SPO_ADMIN_URL=https://<your-tenant>-admin.sharepoint.com

# ID of the Microsoft Search external connection that transcript items are ingested into.
SEARCH_EXTERNAL_CONNECTION_ID=

# Category label applied to all transcript items added to Graph.
CATEGORY=

# SharePoint Stream endpoint path appended to file URLs. This value is universal.
STREAM_ENDPOINT=/_layouts/15/stream.aspx

# ── Add-TranscriptsToGraphForStreamUpload.ps1 [Stream] ───────────────────────

# Full URL of the SharePoint site that hosts the Stream videos.
# Update the path segment if your site uses something other than /sites/.
SITE_URL=https://<your-tenant>.sharepoint.com/sites/<your-teamsite>/

# Name of the document library in the SharePoint site that contains the video files.
DOCUMENT_LIBRARY=Videos

# Optional subfolder within the document library to scope the search (e.g., Recordings/2024).
SHAREPOINT_FOLDER=

# Local folder where downloaded .vtt transcript files are saved.
DESTINATION_FOLDER=C:\Temp

# ── Add-TranscriptsToGraphForTeamsMeeting.ps1 [Teams] ────────────────────────

# Tenant GUID (different from the tenant name above).
TENANT_ID=

# Certificate store path where the auth certificate is located.
CERT_STORE=Cert:\CurrentUser\My\

# Base URL for the meeting organizer's OneDrive.
ONEDRIVE_BASE_URL=https://<your-tenant>-my.sharepoint.com

# UPN (email address) of the Teams meeting organizer.
MEETING_ORGANIZER_UPN=

# Subject line of the Teams meeting to look up.
MEETING_SUBJECT=

# UTC date/time range to search for the meeting recording (ISO 8601 format).
START_DATETIME=2025-02-09T00:00:00Z
END_DATETIME=2025-02-12T11:59:59Z

# Local folder where the downloaded transcript .vtt file will be saved.
TRANSCRIPT_FILE_PATH=C:\Temp
